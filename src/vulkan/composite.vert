#version 450

// ============================================================================
// 图层合成 Vertex Shader
// 
// 功能：全屏三角形渲染，无顶点输入，纯过程生成
// 输出标准化设备坐标 (NDC) 和 UV 坐标到 fragment shader
// ============================================================================

// ============================================================================
// 输出到 fragment shader
// ============================================================================
layout(location = 0) out vec2 v_uv;

// ============================================================================
// 主函数
// 
// 使用 gl_VertexIndex 生成覆盖整个屏幕的三角形：
//   顶点 0: (-1, -1) → 左下，UV (0, 0)
//   顶点 1: ( 3, -1) → 右下（超出屏幕右侧），UV (2, 0)
//   顶点 2: (-1,  3) → 左上（超出屏幕上方），UV (0, 2)
//
// 这个大三角形覆盖了整个 [-1,1]×[-1,1] 的屏幕区域，
// 比两个三角形的 quad 更高效（少一个顶点，无对角线重复像素）
// ============================================================================
const vec2 POSITIONS[3] = vec2[](
    vec2(-1.0, -1.0),
    vec2( 3.0, -1.0),
    vec2(-1.0,  3.0)
);

const vec2 UVS[3] = vec2[](
    vec2(0.0, 0.0),
    vec2(2.0, 0.0),
    vec2(0.0, 2.0)
);

void main() {
    vec2 pos = POSITIONS[gl_VertexIndex];
    gl_Position = vec4(pos, 0.0, 1.0);

    // UV 坐标直接传递，fragment shader 中无需额外计算
    v_uv = UVS[gl_VertexIndex];
}